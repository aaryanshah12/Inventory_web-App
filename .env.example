# Copy this file to .env.local and fill in your values
# .env.local is gitignored and will never be pushed to GitHub

# Supabase (get these from your Supabase project settings)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# SMTP (for sending inquiry emails)
# Gmail: generate an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password

# Email address that receives all inquiries
INQUIRY_TO=info@vidhihexachem.com
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
